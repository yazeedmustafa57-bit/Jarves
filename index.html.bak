<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>J.A.R.V.I.S. - Intelligent Interface</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --cyan: #00d4ff;
    --cyan-dim: rgba(0, 212, 255, 0.15);
    --cyan-glow: rgba(0, 212, 255, 0.4);
    --blue: #0088ff;
    --dark: #0a0e17;
    --panel-bg: rgba(10, 14, 23, 0.85);
    --text: #e0f0ff;
    --text-dim: rgba(224, 240, 255, 0.5);
    --success: #00ff88;
    --warning: #ffaa00;
    --danger: #ff3355;
    --font-display: 'Orbitron', monospace;
    --font-body: 'Rajdhani', sans-serif;
  }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: var(--font-body);
    overflow: hidden;
    height: 100vh;
    width: 100vw;
    user-select: none;
  }

  /* Scan lines overlay */
  .scanlines {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 212, 255, 0.015) 2px,
      rgba(0, 212, 255, 0.015) 4px
    );
    pointer-events: none;
    z-index: 100;
  }

  /* Vignette */
  .vignette {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.6) 100%);
    pointer-events: none;
    z-index: 99;
  }

  /* Grid overlay */
  .grid-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image:
      linear-gradient(rgba(0, 212, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 212, 255, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 98;
  }

  /* Canvas */
  #three-canvas {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 1;
  }

  /* Top HUD bar */
  .hud-top {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 60px;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    background: linear-gradient(180deg, rgba(0, 10, 30, 0.9) 0%, transparent 100%);
  }

  .hud-logo {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--cyan);
    letter-spacing: 6px;
    text-transform: uppercase;
  }

  .hud-logo span {
    color: var(--text-dim);
    font-weight: 300;
  }

  .hud-status {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--text-dim);
    letter-spacing: 2px;
  }

  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 10px var(--success);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hud-time {
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--cyan);
    letter-spacing: 3px;
  }

  /* Global stats panels */
  .hud-panels {
    position: fixed;
    top: 70px;
    left: 0;
    right: 0;
    z-index: 40;
    display: flex;
    justify-content: center;
    gap: 20px;
    padding: 0 40px;
  }

  .hud-panel {
    background: var(--panel-bg);
    border: 1px solid var(--cyan-dim);
    border-radius: 4px;
    padding: 10px 18px;
    text-align: center;
    min-width: 120px;
    backdrop-filter: blur(10px);
  }

  .hud-panel .label {
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 2px;
    text-transform: uppercase;
    font-family: var(--font-display);
  }

  .hud-panel .value {
    font-size: 22px;
    font-weight: 600;
    color: var(--cyan);
    font-family: var(--font-display);
    margin-top: 2px;
  }

  .hud-panel .value.glow-green { color: var(--success); text-shadow: 0 0 20px var(--success); }
  .hud-panel .value.glow-warn { color: var(--warning); text-shadow: 0 0 20px var(--warning); }

  /* Bottom controls */
  .controls {
    position: fixed;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .voice-btn {
    width: 80px; height: 80px;
    border-radius: 50%;
    border: 2px solid var(--cyan);
    background: rgba(0, 212, 255, 0.1);
    color: var(--cyan);
    cursor: pointer;
    font-size: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    position: relative;
    backdrop-filter: blur(5px);
  }

  .voice-btn:hover {
    background: rgba(0, 212, 255, 0.2);
    box-shadow: 0 0 30px var(--cyan-glow);
  }

  .voice-btn.listening {
    border-color: var(--danger);
    color: var(--danger);
    background: rgba(255, 51, 85, 0.15);
    box-shadow: 0 0 40px rgba(255, 51, 85, 0.3);
    animation: pulse-listening 1.5s ease-in-out infinite;
  }

  @keyframes pulse-listening {
    0%, 100% { box-shadow: 0 0 20px rgba(255, 51, 85, 0.2); }
    50% { box-shadow: 0 0 60px rgba(255, 51, 85, 0.5); }
  }

  .voice-btn .ripple {
    position: absolute;
    top: 50%; left: 50%;
    width: 0; height: 0;
    border-radius: 50%;
    border: 1px solid var(--cyan);
    transform: translate(-50%, -50%);
  }

  .voice-btn.listening .ripple {
    animation: ripple-expand 2s ease-out infinite;
  }

  @keyframes ripple-expand {
    0% { width: 80px; height: 80px; opacity: 1; }
    100% { width: 200px; height: 200px; opacity: 0; }
  }

  .voice-btn .ripple:nth-child(2) { animation-delay: 0.5s; }
  .voice-btn .ripple:nth-child(3) { animation-delay: 1s; }

  .input-row {
    display: flex;
    gap: 10px;
    align-items: center;
    background: var(--panel-bg);
    border: 1px solid var(--cyan-dim);
    border-radius: 8px;
    padding: 4px;
    backdrop-filter: blur(10px);
    min-width: 400px;
  }

  .input-row input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 16px;
    padding: 12px 16px;
    letter-spacing: 0.5px;
  }

  .input-row input::placeholder {
    color: var(--text-dim);
    font-family: var(--font-body);
  }

  .input-row button {
    background: var(--cyan-dim);
    border: 1px solid var(--cyan-dim);
    color: var(--cyan);
    padding: 10px 20px;
    border-radius: 6px;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .input-row button:hover {
    background: rgba(0, 212, 255, 0.25);
    border-color: var(--cyan);
  }

  /* Conversation panel */
  .conversation {
    position: fixed;
    bottom: 160px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 40;
    max-width: 600px;
    width: 90%;
    max-height: 200px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0 10px;
    mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 100%);
  }

  .conversation::-webkit-scrollbar { width: 2px; }
  .conversation::-webkit-scrollbar-track { background: transparent; }
  .conversation::-webkit-scrollbar-thumb { background: var(--cyan-dim); border-radius: 2px; }

  .msg {
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 14px;
    line-height: 1.5;
    animation: msg-fade 0.3s ease;
    max-width: 90%;
  }

  .msg.user {
    background: rgba(0, 212, 255, 0.08);
    border-left: 2px solid var(--cyan);
    align-self: flex-end;
    color: var(--cyan);
  }

  .msg.jarvis {
    background: rgba(0, 136, 255, 0.05);
    border-left: 2px solid var(--blue);
    align-self: flex-start;
    color: var(--text);
  }

  .msg.jarvis .prefix {
    color: var(--blue);
    font-weight: 600;
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 2px;
  }

  .msg.user .prefix {
    color: var(--cyan);
    font-weight: 600;
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 2px;
  }

  @keyframes msg-fade {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Goals panel */
  .goals-panel {
    position: fixed;
    right: 30px;
    top: 80px;
    z-index: 45;
    background: var(--panel-bg);
    border: 1px solid var(--cyan-dim);
    border-radius: 6px;
    padding: 16px;
    min-width: 220px;
    backdrop-filter: blur(10px);
  }

  .goals-panel .title {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--text-dim);
    margin-bottom: 12px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .goals-panel .title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--cyan-dim), transparent);
  }

  .goal-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(0, 212, 255, 0.05);
    font-size: 14px;
    color: var(--text);
  }

  .goal-item:last-child { border-bottom: none; }

  .goal-item .status-indicator {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .goal-item .status-indicator.active {
    background: var(--cyan);
    box-shadow: 0 0 8px var(--cyan);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .goal-item .status-indicator.complete {
    background: var(--success);
    box-shadow: 0 0 8px var(--success);
  }

  .goal-item .goal-text {
    flex: 1;
    font-weight: 400;
  }

  .goal-item .goal-progress {
    font-family: var(--font-display);
    font-size: 12px;
    color: var(--text-dim);
  }

  .goals-empty {
    font-size: 13px;
    color: var(--text-dim);
    font-style: italic;
    padding: 4px 0;
  }

  /* Voice waveform visualization */
  .waveform {
    position: fixed;
    bottom: 135px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 45;
    display: flex;
    align-items: center;
    gap: 3px;
    height: 30px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .waveform.active { opacity: 1; }

  .waveform .bar {
    width: 3px;
    background: var(--cyan);
    border-radius: 2px;
    height: 5px;
    animation: wave 0.5s ease-in-out infinite alternate;
  }

  .waveform .bar:nth-child(1) { animation-delay: 0.0s; height: 12px; }
  .waveform .bar:nth-child(2) { animation-delay: 0.1s; height: 8px; }
  .waveform .bar:nth-child(3) { animation-delay: 0.2s; height: 18px; }
  .waveform .bar:nth-child(4) { animation-delay: 0.05s; height: 6px; }
  .waveform .bar:nth-child(5) { animation-delay: 0.15s; height: 22px; }
  .waveform .bar:nth-child(6) { animation-delay: 0.25s; height: 14px; }
  .waveform .bar:nth-child(7) { animation-delay: 0.08s; height: 10px; }
  .waveform .bar:nth-child(8) { animation-delay: 0.18s; height: 20px; }
  .waveform .bar:nth-child(9) { animation-delay: 0.28s; height: 8px; }
  .waveform .bar:nth-child(10) { animation-delay: 0.12s; height: 16px; }
  .waveform .bar:nth-child(11) { animation-delay: 0.22s; height: 7px; }
  .waveform .bar:nth-child(12) { animation-delay: 0.03s; height: 14px; }

  @keyframes wave {
    0% { height: 5px; opacity: 0.3; }
    100% { height: 25px; opacity: 1; }
  }

  /* Corner decorations */
  .corner-deco {
    position: fixed;
    z-index: 50;
    pointer-events: none;
  }

  .corner-deco.tl { top: 20px; left: 20px; }
  .corner-deco.tr { top: 20px; right: 20px; transform: scaleX(-1); }
  .corner-deco.bl { bottom: 20px; left: 20px; transform: scaleY(-1); }
  .corner-deco.br { bottom: 20px; right: 20px; transform: scale(-1, -1); }

  .corner-deco svg { width: 40px; height: 40px; }

  /* Emotion indicator on orb label */
  .orb-label {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    pointer-events: none;
    text-align: center;
  }

  .orb-label .main {
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 6px;
    color: rgba(0, 212, 255, 0.3);
    text-transform: uppercase;
    margin-top: 180px;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .orb-label .sub {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 3px;
    color: rgba(0, 212, 255, 0.15);
    margin-top: 4px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hud-top { padding: 0 16px; }
    .hud-panels { gap: 8px; padding: 0 16px; }
    .hud-panel { min-width: 80px; padding: 6px 10px; }
    .hud-panel .value { font-size: 16px; }
    .goals-panel { right: 10px; top: 70px; min-width: 160px; }
    .input-row { min-width: unset; width: calc(100vw - 40px); }
    .conversation { max-width: calc(100vw - 40px); max-height: 120px; bottom: 150px; }
    .hud-logo { font-size: 14px; letter-spacing: 3px; }
  }
</style>
</head>
<body>

  <!-- 3D Canvas -->
  <div id="three-canvas"></div>

  <!-- Overlays -->
  <div class="scanlines"></div>
  <div class="vignette"></div>
  <div class="grid-overlay"></div>

  <!-- Corner Decorations -->
  <div class="corner-deco tl">
    <svg viewBox="0 0 40 40" fill="none" stroke="rgba(0,212,255,0.3)" stroke-width="1">
      <path d="M38 38 V2 H2" />
      <path d="M38 12 V2 H12" stroke-width="0.5" />
    </svg>
  </div>
  <div class="corner-deco tr"><svg viewBox="0 0 40 40" fill="none" stroke="rgba(0,212,255,0.3)" stroke-width="1"><path d="M2 38 V2 H38"/><path d="M2 12 V2 H12" stroke-width="0.5"/></svg></div>
  <div class="corner-deco bl"><svg viewBox="0 0 40 40" fill="none" stroke="rgba(0,212,255,0.3)" stroke-width="1"><path d="M38 2 V38 H2"/><path d="M38 28 V38 H28" stroke-width="0.5"/></svg></div>
  <div class="corner-deco br"><svg viewBox="0 0 40 40" fill="none" stroke="rgba(0,212,255,0.3)" stroke-width="1"><path d="M2 2 V38 H38"/><path d="M2 28 V38 H28" stroke-width="0.5"/></svg></div>

  <!-- Orb Label -->
  <div class="orb-label">
    <div class="main" id="orbStatus">SYSTEM STANDBY</div>
    <div class="sub">· J.A.R.V.I.S ·</div>
  </div>

  <!-- Top HUD -->
  <div class="hud-top">
    <div class="hud-logo">J.A.R.V.I.S <span>//</span> Mk.V</div>
    <div class="hud-status">
      <div class="status-dot"></div>
      <span id="statusText">ONLINE</span>
    </div>
    <div class="hud-time" id="hudTime">00:00:00</div>
  </div>

  <!-- Stats Panels -->
  <div class="hud-panels">
    <div class="hud-panel">
      <div class="label">System</div>
      <div class="value glow-green" id="sysStatus">ACTIVE</div>
    </div>
    <div class="hud-panel">
      <div class="label">Tasks</div>
      <div class="value" id="taskCount">0</div>
    </div>
    <div class="hud-panel">
      <div class="label">Success Rate</div>
      <div class="value" id="successRate">0%</div>
    </div>
  </div>

  <!-- Goals Panel -->
  <div class="goals-panel" id="goalsPanel">
    <div class="title">Objectives</div>
    <div id="goalsList">
      <div class="goals-empty">No active goals. Tell me your objective.</div>
    </div>
  </div>

  <!-- Conversation -->
  <div class="conversation" id="conversation"></div>

  <!-- Waveform -->
  <div class="waveform" id="waveform">
    <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
    <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
    <div class="bar"></div><div class="bar"></div>
  </div>

  <!-- Bottom Controls -->
  <div class="controls">
    <div class="input-row">
      <input type="text" id="textInput" placeholder="Tell me your objective, sir..." autofocus />
      <button id="sendBtn">Execute</button>
    </div>
    <button class="voice-btn" id="voiceBtn" title="Activate voice command">
      <span class="ripple"></span>
      <span class="ripple"></span>
      <span class="ripple"></span>
      &#x1F3A4;
    </button>
  </div>

  <script type="importmap">
  {
    "imports": {
      "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js"
    }
  }
  </script>

  <script type="module">
  import * as THREE from 'three';

  // -------- 3D SCENE --------
  const container = document.getElementById('three-canvas');
  const scene = new THREE.Scene();

  const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
  camera.position.set(0, 1.5, 5);
  camera.lookAt(0, 0, 0);

  const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setClearColor(0x000000, 0);
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.5;
  container.appendChild(renderer.domElement);

  // Lights
  const ambient = new THREE.AmbientLight(0x004466, 0.5);
  scene.add(ambient);

  const dirLight = new THREE.DirectionalLight(0x00aaff, 2);
  dirLight.position.set(2, 3, 4);
  scene.add(dirLight);

  const dirLight2 = new THREE.DirectionalLight(0x0066cc, 1.5);
  dirLight2.position.set(-3, -1, -2);
  scene.add(dirLight2);

  const pointLight = new THREE.PointLight(0x0088ff, 3, 10);
  pointLight.position.set(0, 0, 0);
  scene.add(pointLight);

  // -------- CORE ORB --------
  const orbGroup = new THREE.Group();
  scene.add(orbGroup);

  // Main sphere
  const sphereGeo = new THREE.SphereGeometry(1, 64, 64);
  const sphereMat = new THREE.MeshPhysicalMaterial({
    color: 0x0088ff,
    emissive: 0x0044aa,
    emissiveIntensity: 0.3,
    metalness: 0.3,
    roughness: 0.2,
    transparent: true,
    opacity: 0.85,
    clearcoat: 0.8,
    clearcoatRoughness: 0.2,
    envMapIntensity: 1.0,
  });
  const sphere = new THREE.Mesh(sphereGeo, sphereMat);
  orbGroup.add(sphere);

  // Inner glow sphere
  const innerGeo = new THREE.SphereGeometry(0.85, 48, 48);
  const innerMat = new THREE.MeshBasicMaterial({
    color: 0x0044ff,
    transparent: true,
    opacity: 0.15,
  });
  const innerSphere = new THREE.Mesh(innerGeo, innerMat);
  orbGroup.add(innerSphere);

  // Outer glow shell
  const glowGeo = new THREE.SphereGeometry(1.15, 48, 48);
  const glowMat = new THREE.ShaderMaterial({
    transparent: true,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
    uniforms: {
      uTime: { value: 0 },
    },
    vertexShader: `
      varying vec3 vNormal;
      varying vec3 vPosition;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vPosition = (modelViewMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `,
    fragmentShader: `
      uniform float uTime;
      varying vec3 vNormal;
      varying vec3 vPosition;
      void main() {
        float intensity = pow(0.75 - dot(vNormal, vec3(0.0, 0.0, 1.0)), 2.5);
        float pulse = 0.8 + 0.2 * sin(uTime * 0.8);
        float fresnel = intensity * pulse;
        gl_FragColor = vec4(0.0, 0.6 + 0.3 * sin(uTime * 0.5), 1.0, fresnel * 0.4);
      }
    `,
  });
  const glowSphere = new THREE.Mesh(glowGeo, glowMat);
  orbGroup.add(glowSphere);

  // Wireframe sphere
  const wireGeo = new THREE.SphereGeometry(1.05, 24, 18);
  const wireMat = new THREE.MeshBasicMaterial({
    color: 0x00aaff,
    wireframe: true,
    transparent: true,
    opacity: 0.12,
  });
  const wireSphere = new THREE.Mesh(wireGeo, wireMat);
  orbGroup.add(wireSphere);

  // -------- RING SYSTEM --------
  function createRing(radius, tubeSize, color, opacity, emissiveIntensity = 0.3) {
    const geo = new THREE.TorusGeometry(radius, tubeSize, 24, 64);
    const mat = new THREE.MeshPhysicalMaterial({
      color: color,
      emissive: color,
      emissiveIntensity: emissiveIntensity,
      transparent: true,
      opacity: opacity,
      metalness: 0.3,
      roughness: 0.4,
      side: THREE.DoubleSide,
      depthWrite: false,
    });
    return new THREE.Mesh(geo, mat);
  }

  // Outer rings
  const ring1 = createRing(1.6, 0.02, 0x00ccff, 0.4);
  ring1.rotation.x = Math.PI * 0.2;
  orbGroup.add(ring1);

  const ring2 = createRing(1.9, 0.015, 0x0066ff, 0.3);
  ring2.rotation.x = Math.PI * 0.7;
  ring2.rotation.z = Math.PI * 0.3;
  orbGroup.add(ring2);

  const ring3 = createRing(2.2, 0.01, 0x0088ff, 0.2);
  ring3.rotation.y = Math.PI * 0.4;
  ring3.rotation.x = Math.PI * 0.5;
  orbGroup.add(ring3);

  // Thin detail rings
  const ring4 = createRing(1.4, 0.005, 0x00ddff, 0.25);
  ring4.rotation.y = Math.PI * 0.8;
  ring4.rotation.x = Math.PI * 0.15;
  orbGroup.add(ring4);

  // -------- PARTICLE SYSTEM --------
  const particleCount = 2000;
  const positions = new Float32Array(particleCount * 3);
  const colors = new Float32Array(particleCount * 3);
  const sizes = new Float32Array(particleCount);

  for (let i = 0; i < particleCount; i++) {
    const radius = 2 + Math.random() * 4;
    const theta = Math.random() * Math.PI * 2;
    const phi = Math.acos(2 * Math.random() - 1);

    positions[i * 3] = radius * Math.sin(phi) * Math.cos(theta);
    positions[i * 3 + 1] = radius * Math.cos(phi) * 0.6;
    positions[i * 3 + 2] = radius * Math.sin(phi) * Math.sin(theta);

    const c = 0.3 + Math.random() * 0.7;
    colors[i * 3] = 0.2 + Math.random() * 0.3;
    colors[i * 3 + 1] = 0.5 + Math.random() * 0.5;
    colors[i * 3 + 2] = 0.8 + Math.random() * 0.2;

    sizes[i] = 0.02 + Math.random() * 0.06;
  }

  const particleGeo = new THREE.BufferGeometry();
  particleGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  particleGeo.setAttribute('color', new THREE.BufferAttribute(colors, 3));
  particleGeo.setAttribute('size', new THREE.BufferAttribute(sizes, 1));

  const particleMat = new THREE.PointsMaterial({
    size: 0.04,
    vertexColors: true,
    transparent: true,
    opacity: 0.7,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
    sizeAttenuation: true,
  });
  const particles = new THREE.Points(particleGeo, particleMat);
  orbGroup.add(particles);

  // Additional small close-orb particles
  const closeParticleCount = 500;
  const closePos = new Float32Array(closeParticleCount * 3);
  for (let i = 0; i < closeParticleCount; i++) {
    const radius = 1.1 + Math.random() * 0.5;
    const theta = Math.random() * Math.PI * 2;
    const phi = Math.acos(2 * Math.random() - 1);
    closePos[i * 3] = radius * Math.sin(phi) * Math.cos(theta);
    closePos[i * 3 + 1] = radius * Math.cos(phi);
    closePos[i * 3 + 2] = radius * Math.sin(phi) * Math.sin(theta);
  }
  const closeParticleGeo = new THREE.BufferGeometry();
  closeParticleGeo.setAttribute('position', new THREE.BufferAttribute(closePos, 3));
  const closeParticleMat = new THREE.PointsMaterial({
    size: 0.015,
    color: 0x00ccff,
    transparent: true,
    opacity: 0.4,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
    sizeAttenuation: true,
  });
  const closeParticles = new THREE.Points(closeParticleGeo, closeParticleMat);
  orbGroup.add(closeParticles);

  // -------- FLOATING DATA RINGS (holographic) --------
  function createDataRing(radius, yOffset, segments = 32) {
    const points = [];
    for (let i = 0; i <= segments; i++) {
      const theta = (i / segments) * Math.PI * 2;
      const x = radius * Math.cos(theta);
      const z = radius * Math.sin(theta);
      points.push(new THREE.Vector3(x, yOffset, z));
    }
    const geo = new THREE.BufferGeometry().setFromPoints(points);
    const mat = new THREE.LineBasicMaterial({
      color: 0x00aaff,
      transparent: true,
      opacity: 0.08 + Math.random() * 0.06,
      blending: THREE.AdditiveBlending,
    });
    return new THREE.Line(geo, mat);
  }

  for (let i = 0; i < 8; i++) {
    const ring = createDataRing(1.3 + i * 0.25, -0.8 + i * 0.2);
    ring.rotation.x = Math.PI * 0.1 * (i % 3);
    orbGroup.add(ring);
  }

  // -------- MOUSE TRACKING --------
  let mouseX = 0;
  let mouseY = 0;
  let targetMouseX = 0;
  let targetMouseY = 0;

  document.addEventListener('mousemove', (e) => {
    targetMouseX = (e.clientX / window.innerWidth) * 2 - 1;
    targetMouseY = -(e.clientY / window.innerHeight) * 2 + 1;
  });

  // -------- SCENE VISUAL STATE --------
  let orbState = 'idle'; // idle | listening | processing | responding
  let stateTransitionTime = 0;

  function setOrbState(state) {
    orbState = state;
    stateTransitionTime = performance.now() / 1000;
    const el = document.getElementById('orbStatus');
    if (state === 'listening') el.textContent = '● LISTENING';
    else if (state === 'processing') el.textContent = '◆ PROCESSING';
    else if (state === 'responding') el.textContent = '► RESPONDING';
    else el.textContent = 'SYSTEM STANDBY';
  }

  // -------- ANIMATION --------
  const clock = new THREE.Clock();

  function animate() {
    requestAnimationFrame(animate);

    const time = clock.getElapsedTime();
    const dt = clock.getDelta();

    // Smooth mouse
    mouseX += (targetMouseX - mouseX) * 0.05;
    mouseY += (targetMouseY - mouseY) * 0.05;

    // Orb rotation
    orbGroup.rotation.y = time * 0.15;
    orbGroup.rotation.x = Math.sin(time * 0.08) * 0.05;

    // Subtle mouse parallax
    orbGroup.rotation.x += mouseY * 0.05;
    orbGroup.rotation.y += mouseX * 0.1;

    // Sphere breathing
    const breathe = 1 + Math.sin(time * 0.6) * 0.008;
    sphere.scale.set(breathe, breathe, breathe);

    // Glow shader time
    glowMat.uniforms.uTime.value = time;

    // Ring rotations
    ring1.rotation.z = time * 0.3;
    ring2.rotation.z = -time * 0.2;
    ring3.rotation.y = time * 0.4;
    ring4.rotation.y = -time * 0.5;
    ring4.rotation.x = Math.PI * 0.15 + Math.sin(time * 0.3) * 0.1;

    // Particle movement - gentle orbit
    const pos = particles.geometry.attributes.position.array;
    for (let i = 0; i < particleCount; i++) {
      const i3 = i * 3;
      const x = pos[i3];
      const z = pos[i3 + 2];
      const speed = 0.05 + (i % 10) * 0.01;
      const angle = speed * dt * 10;
      const newX = x * Math.cos(angle) - z * Math.sin(angle);
      const newZ = x * Math.sin(angle) + z * Math.cos(angle);
      pos[i3] = newX;
      pos[i3 + 2] = newZ;
    }
    particles.geometry.attributes.position.needsUpdate = true;

    // Close particles
    const cpos = closeParticles.geometry.attributes.position.array;
    for (let i = 0; i < closeParticleCount; i++) {
      const i3 = i * 3;
      const x = cpos[i3];
      const z = cpos[i3 + 2];
      const angle = 0.02 * dt * 10;
      const newX = x * Math.cos(angle) - z * Math.sin(angle);
      const newZ = x * Math.sin(angle) + z * Math.cos(angle);
      cpos[i3] = newX;
      cpos[i3 + 2] = newZ;
    }
    closeParticles.geometry.attributes.position.needsUpdate = true;

    // State-based visual effects
    const stateTime = time - stateTransitionTime;
    if (orbState === 'listening') {
      const pulse = 0.8 + 0.2 * Math.sin(stateTime * 4);
      sphereMat.emissiveIntensity = 0.3 + pulse * 0.4;
      sphereMat.emissive.setHex(0xff2244);
      pointLight.color.setHex(0xff2244);
      pointLight.intensity = 3 + pulse * 2;
    } else if (orbState === 'processing') {
      const pulse = 0.5 + 0.5 * Math.sin(stateTime * 6);
      sphereMat.emissiveIntensity = 0.3 + pulse * 0.5;
      sphereMat.emissive.setHex(0xff8800);
      pointLight.color.setHex(0xff8800);
      pointLight.intensity = 3 + pulse * 3;
    } else if (orbState === 'responding') {
      const pulse = 0.7 + 0.3 * Math.sin(stateTime * 2);
      sphereMat.emissiveIntensity = 0.3 + pulse * 0.3;
      sphereMat.emissive.setHex(0x00ff88);
      pointLight.color.setHex(0x00ff88);
      pointLight.intensity = 3 + pulse * 1.5;
    } else {
      sphereMat.emissiveIntensity = 0.3;
      sphereMat.emissive.setHex(0x0044aa);
      pointLight.color.setHex(0x0088ff);
      pointLight.intensity = 3;
    }

    camera.position.x = Math.sin(time * 0.03) * 0.3;
    camera.position.y = 1.5 + Math.sin(time * 0.05) * 0.1;
    camera.lookAt(0, 0, 0);

    renderer.render(scene, camera);
  }

  animate();

  // -------- RESIZE --------
  window.addEventListener('resize', () => {
    const w = window.innerWidth;
    const h = window.innerHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  });

  // -------- CLOCK --------
  function updateClock() {
    const now = new Date();
    document.getElementById('hudTime').textContent =
      now.toTimeString().split(' ')[0];
  }
  setInterval(updateClock, 1000);
  updateClock();

  // Expose for UI interaction
  window.__setOrbState = setOrbState;
  window.__orbGroup = orbGroup;
</script>

<script>
// -------- UI APPLICATION LOGIC --------

const textInput = document.getElementById('textInput');
const sendBtn = document.getElementById('sendBtn');
const voiceBtn = document.getElementById('voiceBtn');
const conversation = document.getElementById('conversation');
const waveform = document.getElementById('waveform');
const goalsList = document.getElementById('goalsList');
const taskCountEl = document.getElementById('taskCount');
const successRateEl = document.getElementById('successRate');
const sysStatusEl = document.getElementById('sysStatus');
const statusTextEl = document.getElementById('statusText');

let goals = [];
let messages = [];
let isListening = false;
let recognition = null;
let speechSynth = window.speechSynthesis;

// Speech Recognition setup
const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

if (SpeechRecognition) {
  recognition = new SpeechRecognition();
  recognition.continuous = false;
  recognition.lang = 'de-DE';
  recognition.interimResults = false;
  recognition.maxAlternatives = 1;

  recognition.onstart = () => {
    isListening = true;
    voiceBtn.classList.add('listening');
    waveform.classList.add('active');
    if (window.__setOrbState) window.__setOrbState('listening');
    statusTextEl.textContent = 'LISTENING';
  };

  recognition.onresult = (event) => {
    const transcript = event.results[0][0].transcript;
    textInput.value = transcript;
    handleUserInput(transcript);
  };

  recognition.onerror = (event) => {
    console.error('Speech error:', event.error);
    stopListening();
    if (event.error !== 'no-speech') {
      addMessage('jarvis', 'I had trouble understanding you. Please try again or type your objective.');
    }
  };

  recognition.onend = () => {
    stopListening();
  };
} else {
  voiceBtn.style.opacity = '0.3';
  voiceBtn.title = 'Speech recognition not supported in this browser';
}

function stopListening() {
  isListening = false;
  voiceBtn.classList.remove('listening');
  waveform.classList.remove('active');
  if (window.__setOrbState) window.__setOrbState('idle');
  statusTextEl.textContent = 'ONLINE';
}

voiceBtn.addEventListener('click', () => {
  if (!recognition) {
    addMessage('jarvis', 'Speech recognition is not available in this browser. Please type your command instead.');
    return;
  }

  if (isListening) {
    recognition.stop();
  } else {
    try {
      recognition.start();
    } catch (e) {
      console.error(e);
    }
  }
});

// Send button
sendBtn.addEventListener('click', () => {
  const text = textInput.value.trim();
  if (text) {
    handleUserInput(text);
    textInput.value = '';
  }
});

textInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') {
    sendBtn.click();
  }
});

// Jarvis responses
const jarvisResponses = {
  greeting: [
    'At your service, sir. What objective shall we pursue today?',
    'Welcome back. I am ready to assist with your objectives.',
    'Systems are online and ready. What is our goal?',
  ],
  goal: [
    'I have logged this objective. I will assist you in achieving it.',
    'Objective recorded. I will allocate resources accordingly.',
    'Goal registered. Let me know how you wish to proceed.',
  ],
  earn: [
    'An excellent objective. I will begin analyzing revenue opportunities.',
    'I have initiated a financial growth protocol. Shall I detail the strategy?',
    'Profit generation is a worthy goal. I am already conducting market analysis.',
  ],
  unknown: [
    'I am processing your request. Could you provide more details?',
    'I am not entirely sure how to categorize that. Please elaborate.',
    'Understood. I will adapt my protocols accordingly.',
  ],
  status: [
    'All systems are functioning within expected parameters.',
    'System integrity is at 100%. No anomalies detected.',
    'Everything is running smoothly. Ready for your command.',
  ],
};

function pickRandom(arr) {
  return arr[Math.floor(Math.random() * arr.length)];
}

function addMessage(type, text) {
  const div = document.createElement('div');
  div.className = `msg ${type}`;
  const prefix = type === 'jarvis' ? 'J.A.R.V.I.S' : 'YOU';
  div.innerHTML = `<span class="prefix">[${prefix}]</span> ${text}`;
  conversation.appendChild(div);
  conversation.scrollTop = conversation.scrollHeight;
}

function addGoal(text) {
  // Check if similar goal exists
  const existing = goals.find(g => g.text.toLowerCase() === text.toLowerCase());
  if (existing) return existing;

  const goal = {
    id: Date.now(),
    text: text,
    status: 'active', // active, complete
    createdAt: new Date().toISOString(),
  };
  goals.push(goal);
  renderGoals();
  updateStats();
  return goal;
}

function completeGoal(id) {
  const goal = goals.find(g => g.id === id);
  if (goal) {
    goal.status = 'complete';
    renderGoals();
    updateStats();
  }
}

function renderGoals() {
  if (goals.length === 0) {
    goalsList.innerHTML = '<div class="goals-empty">No active goals. Tell me your objective.</div>';
    return;
  }

  goalsList.innerHTML = goals.map(g => `
    <div class="goal-item">
      <div class="status-indicator ${g.status}"></div>
      <span class="goal-text">${escapeHtml(g.text)}</span>
      <span class="goal-progress">${g.status === 'complete' ? '✓ DONE' : '◉ ACTIVE'}</span>
    </div>
  `).join('');
}

function updateStats() {
  const active = goals.filter(g => g.status === 'active').length;
  const done = goals.filter(g => g.status === 'complete').length;
  taskCountEl.textContent = active;
  const total = goals.length;
  const rate = total > 0 ? Math.round((done / total) * 100) : 0;
  successRateEl.textContent = rate + '%';
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function categorizeInput(text) {
  const lower = text.toLowerCase();

  if (lower.match(/^(h(e(llo|y))?|yo|hi|hey|servus|hallo|moin|tach|grüß|guten)/)) {
    return 'greeting';
  }
  if (lower.match(/status|online|system|funktion|bereit|aktiv/)) {
    return 'status';
  }
  if (lower.match(/(verdien|euro|\d+\s*€|geld|profit|einkommen|umsatz)/)) {
    return 'earn';
  }
  if (lower.match(/(ziel|goal|aufgabe|objective|mission|erreichen|schaffen|machen|bauen|erstellen)/)) {
    return 'goal';
  }
  return 'unknown';
}

function getJarvisResponse(category, userText) {
  if (category === 'greeting') return pickRandom(jarvisResponses.greeting);
  if (category === 'status') return pickRandom(jarvisResponses.status);
  if (category === 'earn') return pickRandom(jarvisResponses.earn);
  if (category === 'goal') return pickRandom(jarvisResponses.goal);
  return pickRandom(jarvisResponses.unknown);
}

function speakText(text) {
  if (!speechSynth) return;
  window.speechSynthesis.cancel();
  const utterance = new SpeechSynthesisUtterance(text);
  utterance.lang = 'en-US';
  utterance.rate = 0.92;
  utterance.pitch = 0.7;
  utterance.volume = 0.8;

  // Find a good voice
  const voices = speechSynth.getVoices();
  const preferredVoice = voices.find(v => v.name.includes('Google UK') || v.name.includes('British'));
  if (preferredVoice) utterance.voice = preferredVoice;

  utterance.onstart = () => {
    if (window.__setOrbState) window.__setOrbState('responding');
    statusTextEl.textContent = 'SPEAKING';
  };
  utterance.onend = () => {
    if (window.__setOrbState) window.__setOrbState('idle');
    statusTextEl.textContent = 'ONLINE';
  };

  speechSynth.speak(utterance);
}

function handleUserInput(text) {
  if (!text) return;

  addMessage('user', text);
  stopListening();

  // Set processing state briefly
  if (window.__setOrbState) window.__setOrbState('processing');
  statusTextEl.textContent = 'PROCESSING';

  // Extract potential goal
  const lower = text.toLowerCase();
  let extractedGoal = null;

  // Check if this sounds like setting a goal
  if (lower.match(/(ich möchte|ich will|ich würde|ich werde|ziel|erreichen|schaffen|bauen|erstellen|holen|besorgen|bekommen)/) ||
      lower.match(/(verdienen|euro|€|geld)/)) {
    // Clean up the text for the goal
    extractedGoal = text
      .replace(/^(ich möchte|ich will|ich würde|ich werde|hilf mir|kannst du|ich brauche)/i, '')
      .replace(/^(bitte|dass ich)/i, '')
      .trim();
    if (!extractedGoal || extractedGoal.length < 3) extractedGoal = text;
  }

  // Simulate processing delay
  setTimeout(() => {
    const category = categorizeInput(text);
    let response = getJarvisResponse(category, text);

    // If it's an earn-related goal, customize the response
    if (category === 'earn') {
      const match = text.match(/(\d+([.,]\d+)?)\s*(€|euro|eur)/i);
      const amount = match ? match[1] : null;
      if (amount) {
        response = `Objective logged: Generate ${amount}€. I have begun analyzing optimal revenue streams, market opportunities, and resource allocation to achieve this target. Shall I present the strategy?`;
      }
    }

    // If we detected a goal, add it
    if (extractedGoal) {
      addGoal(extractedGoal);
      if (category === 'unknown') {
        response = `I have registered your objective: "${extractedGoal}". I will assist you in achieving it.`;
      }
    }

    addMessage('jarvis', response);

    // Speak the response
    speakText(response);

    // Update system status
    sysStatusEl.textContent = 'ACTIVE';
    updateStats();
  }, 800 + Math.random() * 600);
}

// Initial greeting
setTimeout(() => {
  addMessage('jarvis', 'Good day, sir. J.A.R.V.I.S. is online. What is our objective today?');
  speakText('Good day, sir. J.A.R.V.I.S. is online. What is our objective today?');
}, 1000);

// Load voices for speech
if (speechSynth) {
  speechSynth.getVoices(); // Prime the voices
  speechSynth.onvoiceschanged = () => { speechSynth.getVoices(); };
}
</script>
</body>
</html>
